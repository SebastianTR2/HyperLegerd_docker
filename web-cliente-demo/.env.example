# Opcional: URL absoluta del middleware (sin proxy). Por defecto la app usa /api con proxy de Vite.
# VITE_API_BASE=http://127.0.0.1:3000

# Proxy del dev server: use 127.0.0.1:3000 en la misma máquina (evitar 169.254.x.x sin puerto).
# VITE_API_TARGET=http://127.0.0.1:3000

# Enlace al Explorer para mensajes en pantalla
# VITE_EXPLORER_URL=http://localhost:8081

# URL base del Portal de Cliente (registro operativo). Por defecto se usa http://localhost:5174
# VITE_PORTAL_CLIENTE_URL=http://localhost:5174
