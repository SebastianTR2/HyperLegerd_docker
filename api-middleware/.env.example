# Copiar a `.env` y rellenar valores. No commitear `.env` con secretos reales.

# =============================================================================
# Modo multi-tenant (recomendado)
# =============================================================================
# Si se define TENANTS_FILE y existe el archivo, el middleware carga la
# configuración multi-tenant (config/tenants.yaml) y las variables siguientes
# (single-tenant) se ignoran salvo las API keys legacy.
# TENANTS_FILE=./config/tenants.yaml
# CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# =============================================================================
# Modo single-tenant legacy (compatibilidad)
# =============================================================================
# Si TENANTS_FILE no está definido o el archivo no existe, se usan estas vars
# para conectar a una única Org/canal/chaincode. Las API keys siguientes se
# mapean automáticamente al tenant "clientes".

# --- API pública (hito 2.6): cabecera X-API-Key ---
API_KEY_ADMIN=
API_KEY_INTEGRADOR=
API_KEY_SOLO_LECTURA=

# --- Rutas /admin/... (sin mezclar con X-API-Key) ---
ADMIN_API_KEY=

# --- Servidor ---
PORT=3000

# --- Hyperledger Fabric (gateway) ---
MSPID=
CERT_PATH=
KEY_PATH_DIR=
TLS_CERT_PATH=
PEER_ENDPOINT=
PEER_HOST_ALIAS=
CHANNEL_NAME=

# Nombre por defecto del chaincode de clientes (cliente_cc en single-tenant)
CHAINCODE_NAME=cliente_cc
# Nombre por defecto del chaincode de tokens (opcional)
TOKEN_CHAINCODE_NAME=token_erc20

# CORS — permitir orígenes separados por coma. En desarrollo se puede usar *.
# Producción: lista explícita de dominios (https://web-agricultura.ejemplo).
CORS_ORIGINS=*

# Opcional: bitácora chaincode + líneas compartidas (JSONL append). Ver CHAINCODE_BITACORA_FILE en documentación interna.
# CHAINCODE_BITACORA_FILE=/tmp/campuschain-bitacora.jsonl

# =============================================================================
# Notificador a administradores (mutaciones detectadas en el ledger)
# =============================================================================
# El notificador se inicia siempre. SIN configurar SMTP funciona en modo
# log-only: los correos que se hubieran enviado se registran en stdout.
# Para envío real, completar las variables NOTIFICADOR_SMTP_*.

# NOTIFICADOR_SMTP_HOST=smtp.gmail.com
# NOTIFICADOR_SMTP_PUERTO=587
# NOTIFICADOR_SMTP_USUARIO=avisos@empresa.com
# NOTIFICADOR_SMTP_CONTRASENA=
# NOTIFICADOR_SMTP_REMITENTE="CampusChain <avisos@empresa.com>"
# NOTIFICADOR_SMTP_STARTTLS=true
# NOTIFICADOR_SMTP_LOG_ONLY=false
