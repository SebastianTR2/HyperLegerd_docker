# Opcional: URL absoluta del middleware (sin proxy). Por defecto la app usa /api con proxy de Vite.
# VITE_API_BASE=http://127.0.0.1:3000

# Target del proxy de Vite en desarrollo (middleware Go). Si el backend está en WSL y el navegador en Windows:
# VITE_API_TARGET=http://<IP-de-WSL>:3000

# Enlace al Explorer para mensajes en pantalla
# VITE_EXPLORER_URL=http://localhost:8081
